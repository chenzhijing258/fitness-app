/* pages/lock/lock.wxss */
.container {
  min-height: 100vh;
  background: var(--bg);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 64rpx 48rpx;
}

.emoji { font-size: 112rpx; margin-bottom: 32rpx; }

.title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text);
  text-align: center;
  line-height: 1.6;
  white-space: pre-line;
}

.error-text {
  color: var(--danger);
  font-size: 26rpx;
  text-align: center;
  margin-top: 20rpx;
}
