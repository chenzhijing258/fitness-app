/* pages/student-detail/student-detail.wxss */
.section-body { margin-top: 24rpx; }

.history-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.pkg-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.fb-row {
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.delta-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.delta-card {
  background: var(--card-2);
  border-radius: 20rpx;
  padding: 20rpx 24rpx;
}

.delta-label { font-size: 22rpx; color: var(--text-muted); }
.delta-value { font-size: 32rpx; font-weight: 700; margin-top: 4rpx; color: var(--text); }
.delta-unit  { font-size: 22rpx; font-weight: 400; color: var(--text-muted); }
.delta-diff  { font-size: 22rpx; }

.metric-chip {
  font-size: 24rpx;
  background: var(--card-2);
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  margin-right: 8rpx;
  margin-bottom: 8rpx;
  display: inline-block;
  color: var(--text);
}

.body-history {
  font-size: 26rpx;
  color: var(--text-muted);
  margin-bottom: 16rpx;
}

.body-entry {
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.tag-row { display: flex; flex-wrap: wrap; margin-top: 12rpx; }
